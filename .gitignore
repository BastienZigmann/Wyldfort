# ---------------------------
# Unreal Engine / General
# ---------------------------

# Visual Studio user-specific
.vs/

# IDE/project files
/.vscode/*
/.idea/*
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.xcodeproj
*.xcworkspace

# OS cruft
.DS_Store
Thumbs.db

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# ---------------------------
# Unreal project outputs
# ---------------------------

# These can be regenerated
Binaries/*
Plugins/*/Binaries/*
Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Editor-generated saved data
Saved/*

# Intermediate build files
Intermediate/*
Plugins/*/Intermediate/*

# Derived data cache
DerivedDataCache/*

# Precompiled Source Art (optional)
SourceArt/**/*.png
SourceArt/**/*.tga

# ---------------------------
# Content policy
# ---------------------------

# External/third-party packs live here and are not tracked
# Put all external/Marketplace packs under: Content/assets/ASSET_NAME
/Content/Assets/**
/Content/Assets

# Optional: ignore typical demo/example content from packs
# (Uncomment or add specific folders if you don't want them tracked)
/Content/**/Demo/**
/Content/**/Examples/**
/Content/**/Example/**
/Content/**/Maps/Example**/
/Content/**/Maps/**

# Optional: ignore StarterContent if you don't want it in Git
# /Content/StarterContent/**